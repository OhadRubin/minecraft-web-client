{
    "name": "minecraft-ts-controller",
    "version": "1.0.0",
    "description": "TypeScript port of Minecraft web controller",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "check": "tsc --noEmit",
        "dev": "tsc --watch",
        "serve": "python -m http.server 8089",
        "start": "tsc --watch & python -m http.server 8089"
    },
    "devDependencies": {
        "typescript": "^5.0.0"
    },
    "keywords": ["minecraft", "controller", "typescript", "websocket"],
    "author": "",
    "license": "MIT"
}